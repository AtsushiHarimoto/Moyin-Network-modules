{
  "name": "@moyin/net-client",
  "version": "1.0.0",
  "description": "Framework-agnostic HTTP client with retry, cancellation, concurrency policies, and streaming support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "http-client",
    "fetch",
    "retry",
    "cancellation",
    "concurrency",
    "streaming",
    "framework-agnostic"
  ],
  "author": "Atsushi Harimoto",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/AtsushiHarimoto/moyin-network-modules.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
